# ============================================
# Configuracao do Mentor PDI
# Copie este arquivo para .env e preencha
# ============================================

# Chave de sessao (gere uma aleatoria em producao)
SECRET_KEY=troque-esta-chave-por-uma-aleatoria-longa

# Banco de dados
# - Rodando local:  sqlite:///./mentorpdi.db
# - Rodando no Docker (volume persistente): sqlite:////data/mentorpdi.db   (4 barras!)
# - Postgres:       postgresql://usuario:senha@host:5432/mentorpdi
DATABASE_URL=sqlite:///./mentorpdi.db

# ---- Integracao com IA ----
# Provider: gemini | anthropic | mock
AI_PROVIDER=gemini

# Google Gemini (gratuito - pegue a chave em https://aistudio.google.com)
# A chave comeca com "AIza..."
GEMINI_API_KEY=coloque-sua-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (alternativa paga)
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-20250514

# Use MOCK apenas para testar a aplicacao sem IA (resposta fixa, NAO usar na entrega)
# AI_PROVIDER=mock
